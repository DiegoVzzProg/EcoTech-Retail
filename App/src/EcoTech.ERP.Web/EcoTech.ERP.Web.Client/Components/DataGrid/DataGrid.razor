@typeparam TItem

<div class="flex flex-col gap-4">
    <div class="flex justify-between items-center text-sm text-gray-400">
        <div class="flex items-center gap-2">
            <span>Mostrar</span>
            <select @bind="PageSize" @bind:after="ResetPage" class="bg-[#1b2735] border border-gray-700 rounded px-2 py-1 text-white focus:outline-none focus:ring-1 focus:ring-blue-500">
                <option value="5">5</option>
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
            </select>
            <span>registros</span>
        </div>
        <div class="flex items-center gap-2">
            <span>Buscar:</span>
            <input type="text" @bind="SearchTerm" @bind:event="oninput" 
                class="bg-[#1b2735] border border-gray-700 rounded px-3 py-1 text-white focus:outline-none focus:ring-1 focus:ring-blue-500" placeholder="..." />
        </div>
    </div>

    <div class="overflow-x-auto rounded-xl border border-slate-800 bg-[#161b22]">
        <table class="w-full text-left text-sm text-slate-300">
            <thead class="bg-[#1c2128] text-xs font-semibold uppercase text-slate-400">
                <tr>
                    @if (ExpandedRowTemplate != null)
                    {
                        <th class="w-10 px-4 py-4 text-center"></th>
                    }
                    @HeaderContent
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-800 overflow-x-auto">
                @if (PaginatedItems != null && PaginatedItems.Any())
                {
                    @foreach (var item in PaginatedItems)
                    {
                        bool isExpanded = _expandedRows.Contains(item);
                        <tr class="transition-colors hover:bg-slate-800/30">
                            @if (ExpandedRowTemplate != null)
                            {
                                <td class="px-4 py-4 text-center cursor-pointer text-blue-400 hover:text-blue-300" @onclick="() => ToggleRow(item)">
                                    <svg class="w-5 h-5 inline-block transform transition-transform @(isExpanded ? "rotate-90" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                                </td>
                            }
                            @RowTemplate(item)
                        </tr>
                        @if (isExpanded && ExpandedRowTemplate != null)
                        {
                            <tr class="bg-[#1b222b]">
                                <td colspan="100%" class="px-6 py-4 border-l-4 border-blue-500">
                                    @ExpandedRowTemplate(item)
                                </td>
                            </tr>
                        }
                    }
                }
                else
                {
                    <tr>
                        <td colspan="100%" class="px-6 py-10 text-center text-slate-500 italic">
                            No se encontraron registros.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="flex justify-between items-center text-sm text-gray-400">
        <div>
            Mostrando @StartRecord al @EndRecord de @TotalItems registros
        </div>

        <div class="flex space-x-1">
            <button @onclick="PreviousPage" disabled="@(!CanGoBack)" class="px-3 py-1 rounded bg-[#1b2735] border border-gray-700 hover:bg-gray-700 disabled:opacity-50 disabled:cursor-not-allowed text-white">
                «
            </button>

            @for (int i = 1; i <= TotalPages; i++)
            {
                int pageNumber = i;
                <button @onclick="() => GoToPage(pageNumber)" class="px-3 py-1 rounded border border-gray-700 @(CurrentPage == pageNumber ? "bg-blue-600 text-white border-blue-600" : "bg-[#1b2735] text-gray-300 hover:bg-gray-700")">
                    @pageNumber
                </button>
            }

            <button @onclick="NextPage" disabled="@(!CanGoForward)" class="px-3 py-1 rounded bg-[#1b2735] border border-gray-700 hover:bg-gray-700 disabled:opacity-50 disabled:cursor-not-allowed text-white">
                »
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public IEnumerable<TItem> Items { get; set; } = Enumerable.Empty<TItem>();
    [Parameter, EditorRequired] public RenderFragment HeaderContent { get; set; } = default!;
    [Parameter, EditorRequired] public RenderFragment<TItem> RowTemplate { get; set; } = default!;

    [Parameter] public RenderFragment<TItem>? ExpandedRowTemplate { get; set; }

    [Parameter] public Func<TItem, string, bool>? SearchPredicate { get; set; }

    private int PageSize { get; set; } = 10;
    private int CurrentPage { get; set; } = 1;
    private string SearchTerm { get; set; } = string.Empty;
    private HashSet<TItem> _expandedRows = new();

    private IEnumerable<TItem> FilteredItems =>
        string.IsNullOrWhiteSpace(SearchTerm) || SearchPredicate == null
        ? Items
        : Items.Where(x => SearchPredicate(x, SearchTerm));

    private IEnumerable<TItem> PaginatedItems =>
        FilteredItems.Skip((CurrentPage - 1) * PageSize).Take(PageSize);

    private int TotalItems => FilteredItems.Count();
    private int TotalPages => (int)Math.Ceiling(TotalItems / (double)PageSize);
    private int StartRecord => TotalItems == 0 ? 0 : ((CurrentPage - 1) * PageSize) + 1;
    private int EndRecord => Math.Min(CurrentPage * PageSize, TotalItems);

    private bool CanGoBack => CurrentPage > 1;
    private bool CanGoForward => CurrentPage < TotalPages;

    private void NextPage() { if (CanGoForward) CurrentPage++; }
    private void PreviousPage() { if (CanGoBack) CurrentPage--; }
    private void GoToPage(int page) => CurrentPage = page;

    private void ResetPage()
    {
        CurrentPage = 1;
        _expandedRows.Clear();
    }

    private void ToggleRow(TItem item)
    {
        if (!_expandedRows.Add(item))
        {
            _expandedRows.Remove(item);
        }
    }
}