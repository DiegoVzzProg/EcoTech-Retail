@typeparam TModel

<EditForm Model="@Model" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />

    <div class="flex flex-col gap-4 bg-[#161f2b] border border-gray-700 rounded-lg p-6">

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            @ChildContent
        </div>

        <div class="flex flex-col lg:flex-row pt-5 mt-2 border-t border-gray-700/50 gap-2">
            <button type="submit"
                    class="px-6 py-2.5 flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium rounded-lg shadow-sm transition-all focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:ring-offset-[#161f2b] w-full">
                @if (Mode == FormMode.Add)
                {
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    <span>Crear @AditionalTextForButton</span>
                }
                else
                {
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                    <span>Editar @AditionalTextForButton</span>
                }
            </button>
            <NavLink href="@LinkForToBackButton" 
                class="px-6 py-2.5 flex items-center justify-center gap-2 bg-slate-800 hover:bg-slate-700 text-slate-200 hover:text-white text-sm font-medium rounded-lg shadow-sm transition-all focus:ring-2 focus:ring-slate-500 focus:ring-offset-2 focus:ring-offset-[#161f2b] w-full">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-left-icon lucide-chevron-left"><path d="m15 18-6-6 6-6" /></svg>
                <span>Volver</span>
            </NavLink>
        </div>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired] public TModel Model { get; set; } = default!;

    [Parameter, EditorRequired] public FormMode Mode { get; set; } = FormMode.Add;

    [Parameter, EditorRequired] public RenderFragment ChildContent { get; set; } = default!;

    [Parameter, EditorRequired] public EventCallback<TModel> OnValidSubmit { get; set; }

    [Parameter, EditorRequired] public string LinkForToBackButton { get; set; }

    [Parameter] public string AditionalTextForButton { get; set; } = string.Empty;

    public enum FormMode
    {
        Add,
        Edit
    }

    private async Task HandleSubmit()
    {
        // Pasa el modelo capturado hacia el componente padre
        await OnValidSubmit.InvokeAsync(Model);
    }
}