<div class="flex flex-col w-full">
    <div class="flex items-center gap-2 text-sm text-gray-400 mb-1">
        @GetFormatDesc()
    </div>
    <h1 class="text-2xl font-bold text-white tracking-tight">@Titulo</h1>
    <p class="text-gray-400 mt-1 text-sm">@Description</p>
</div>

@code {
    [Parameter, EditorRequired] public string Titulo { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Breadcrumbs { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Description { get; set; } = string.Empty;
    [Parameter] public string PrefixGroup { get; set { value = $"<span class='select-none'>{value}</span>"; } } = "<span class='select-none'>Organizacion</span>";

    private MarkupString GetFormatDesc()
    {
        if (string.IsNullOrWhiteSpace(Breadcrumbs)) return (MarkupString)PrefixGroup;

        string[] data = Breadcrumbs.Split('|');

        var formattedParts = data.Select((item, index) =>
        {
            bool isLast = index == data.Length - 1;

            string cssClass = isLast ? "text-gray-200 font-medium" : string.Empty;

            return $"<span class='{cssClass} select-none'>{item}</span>";
        });

        string separator = "<span class='select-none'> / </span>";
        string fullPath = $"{PrefixGroup} {$"{separator} {string.Join(separator, formattedParts)}"}";

        return (MarkupString)fullPath;
    }
}
